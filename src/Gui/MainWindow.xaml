<Window x:Class="ScanPhoneNetwork.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="업무망 무단 장비 점검기" Height="640" Width="980"
        WindowStartupLocation="CenterScreen" FontSize="13"
        KeyDown="OnWindowKeyDown">
    <DockPanel Margin="10">

        <!-- 상단 도구막대 -->
        <Border DockPanel.Dock="Top" Padding="8" Background="#F3F4F6" CornerRadius="6">
            <StackPanel>
                <!-- 기본: 버튼 하나로 '내 네트워크'를 점검 -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="ScanButton" Content="🔍 내 네트워크 스캔" Width="170" Height="36"
                            FontWeight="Bold" Click="OnScanClick"/>
                    <Button x:Name="StopButton" Content="중지" Width="60" Height="36" Margin="6,0,0,0"
                            Click="OnStopClick" IsEnabled="False"/>
                    <Button x:Name="ReportButton" Content="⚠ 상세 보고" Width="110" Height="36" Margin="16,0,0,0"
                            Click="OnReportClick" IsEnabled="False"/>
                    <Button x:Name="CsvButton" Content="CSV 저장" Width="90" Height="36" Margin="6,0,0,0"
                            Click="OnExportClick" IsEnabled="False"/>
                    <TextBlock Text="현재 연결된 네트워크를 점검합니다" Foreground="Gray"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>

                <!-- 숨김(고급): Ctrl+Shift+A 로만 표시. 대역을 직접 지정 -->
                <StackPanel x:Name="AdvancedPanel" Orientation="Horizontal"
                            Margin="0,8,0,0" Visibility="Collapsed">
                    <TextBlock Text="대상 대역:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="TargetBox" Width="170" VerticalContentAlignment="Center"
                             ToolTip="비우면 자동. 예: 10.20.30.0/24"/>
                    <TextBlock Text="(고급: 비우면 자동 탐지 · 예 10.20.30.0/24)" Foreground="Gray"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <CheckBox x:Name="MonitorCheck" Content="감시 모드" VerticalAlignment="Center"
                              Click="OnMonitorToggle"/>
                    <TextBlock Text="주기(분):" VerticalAlignment="Center" Margin="16,0,4,0"/>
                    <TextBox x:Name="IntervalBox" Text="10" Width="40" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="AutoStartCheck" Content="윈도우 시작 시 자동 실행(감시)"
                              VerticalAlignment="Center" Margin="20,0,0,0" Click="OnAutoStartToggle"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 하단 상태 -->
        <Border DockPanel.Dock="Bottom" Padding="6,4" Background="#F3F4F6" Margin="0,8,0,0">
            <DockPanel>
                <TextBlock x:Name="SummaryText" DockPanel.Dock="Right" Foreground="#B91C1C"
                           FontWeight="Bold"/>
                <TextBlock x:Name="StatusText" Text="대기 중"/>
            </DockPanel>
        </Border>

        <ProgressBar x:Name="Progress" DockPanel.Dock="Bottom" Height="6" Margin="0,8,0,0"
                     Minimum="0" Maximum="100"/>

        <!-- 결과 표 -->
        <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserResizeRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" RowBackground="White">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{Binding RowBackground}"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="이 장비를 정상(승인)으로 등록" Click="OnApproveClick"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="130"/>
                <DataGridTextColumn Header="MAC" Binding="{Binding Mac}" Width="150"/>
                <DataGridTextColumn Header="종류" Binding="{Binding Category}" Width="110"/>
                <DataGridTextColumn Header="신뢰도%" Binding="{Binding Confidence}" Width="70"/>
                <DataGridTextColumn Header="제조사" Binding="{Binding Vendor}" Width="160"/>
                <DataGridTextColumn Header="포트" Binding="{Binding OpenPorts}" Width="90"/>
                <DataGridTextColumn Header="근거" Binding="{Binding Evidence}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
